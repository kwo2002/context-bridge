#!/usr/bin/env bash
# AIFlare: mark pushed commits' timeline entries as PUSHED
# Failures never block the push

set -uo pipefail

GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
CONFIG_FILE="${GIT_ROOT}/aiflare.yml"

# Exit silently when aiflare.yml is missing
if [[ ! -f "$CONFIG_FILE" ]]; then
  exit 0
fi

# Read configuration
ENDPOINT="$(grep -E '^endpoint:' "$CONFIG_FILE" | sed 's/^endpoint:[[:space:]]*//' | tr -d '"' | tr -d "'")"
ENDPOINT="${ENDPOINT:-https://api.aiflare.dev}"
API_KEY="$(grep -E '^api_key:' "$CONFIG_FILE" | sed 's/^api_key:[[:space:]]*//' | tr -d '"' | tr -d "'")"

if [[ -z "$API_KEY" ]]; then
  exit 0
fi

# Parse push info from stdin
while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip delete pushes
  if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
    continue
  fi

  # Extract branch name (refs/heads/feature/auth -> feature/auth)
  branch="${local_ref#refs/heads/}"

  # Collect the commit hashes being pushed
  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    # New branch: all local-only commits
    commit_hashes="$(git log "$local_sha" --format="%H" --not --remotes 2>/dev/null || echo "")"
  else
    # Existing branch: commits in remote..local range
    commit_hashes="$(git log "${remote_sha}..${local_sha}" --format="%H" 2>/dev/null || echo "")"
  fi

  if [[ -z "$commit_hashes" ]]; then
    continue
  fi

  # Build JSON array
  json_array="["
  first=true
  while IFS= read -r hash; do
    if [[ -n "$hash" ]]; then
      if [[ "$first" == true ]]; then
        first=false
      else
        json_array+=","
      fi
      json_array+="\"$hash\""
    fi
  done <<< "$commit_hashes"
  json_array+="]"

  # Call the API (ignore failures)
  curl -s -X POST "${ENDPOINT}/api/v1/captures/publish" \
    -H "Content-Type: application/json" \
    -H "X-API-Key: ${API_KEY}" \
    -d "{\"commitHashes\":${json_array},\"branch\":\"${branch}\"}" \
    >/dev/null 2>&1 || true

done

exit 0
